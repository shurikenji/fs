OPERATOR_PORT=8091
OPERATOR_TOKEN=change-me
ROOT_DOMAIN=shupremium.com
WILDCARD_CERT_NAME=shupremium-wildcard
WILDCARD_CERT_DIR=/etc/letsencrypt/live/shupremium-wildcard
CLOUDFLARE_CREDENTIALS=/home/ubuntu/.secrets/cloudflare.ini
PROXY_SERVICE_PATH=/home/ubuntu/proxy-gateway/proxy-service
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
